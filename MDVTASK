<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>MDV Digital Checklist 2026</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --blue: #1B3A6B;
  --teal: #0B7B8C;
  --green: #16a34a;
  --orange: #ea580c;
  --red: #dc2626;
  --purple: #7c3aed;
  --yellow: #d97706;
  --bg: #0f1923;
  --card: #162032;
  --card2: #1c2d42;
  --border: #243550;
  --text: #e2eaf4;
  --muted: #6b8aaa;
  --light: #a8c0d6;
  --white: #ffffff;
}

* { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

/* HEADER */
.header {
  background: linear-gradient(135deg, #0d1e33 0%, #1a3a5c 100%);
  padding: 16px;
  border-bottom: 1px solid var(--border);
  position: sticky;
  top: 0;
  z-index: 200;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.header-title h1 {
  font-size: 15px;
  font-weight: 700;
  color: var(--white);
  letter-spacing: 0.3px;
}

.header-title p {
  font-size: 10px;
  color: var(--muted);
  margin-top: 1px;
  font-family: 'DM Mono', monospace;
}

.header-actions {
  display: flex;
  gap: 8px;
}

.btn-icon {
  background: var(--card2);
  border: 1px solid var(--border);
  color: var(--light);
  border-radius: 8px;
  padding: 6px 10px;
  font-size: 11px;
  font-weight: 600;
  cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  transition: all 0.15s;
}

.btn-icon:active { opacity: 0.7; transform: scale(0.97); }

/* GLOBAL PROGRESS */
.global-progress {
  display: flex;
  align-items: center;
  gap: 10px;
}

.progress-track {
  flex: 1;
  background: rgba(255,255,255,0.08);
  border-radius: 10px;
  height: 6px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--teal), #4ade80);
  border-radius: 10px;
  transition: width 0.5s cubic-bezier(0.4,0,0.2,1);
}

.progress-label {
  font-size: 11px;
  color: var(--light);
  font-family: 'DM Mono', monospace;
  white-space: nowrap;
}

/* TABS */
.tabs-wrap {
  background: var(--card);
  border-bottom: 1px solid var(--border);
  overflow-x: auto;
  scrollbar-width: none;
  position: sticky;
  top: 89px;
  z-index: 199;
}
.tabs-wrap::-webkit-scrollbar { display: none; }

.tabs {
  display: flex;
  padding: 0 4px;
  min-width: max-content;
}

.tab {
  padding: 10px 12px;
  font-size: 11px;
  font-weight: 600;
  color: var(--muted);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  white-space: nowrap;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  gap: 5px;
  font-family: 'DM Sans', sans-serif;
}

.tab.active {
  color: var(--white);
  border-bottom-color: var(--teal);
}

.badge {
  background: var(--card2);
  color: var(--muted);
  border-radius: 20px;
  padding: 1px 6px;
  font-size: 9px;
  font-family: 'DM Mono', monospace;
  border: 1px solid var(--border);
}

.badge.complete { background: rgba(74,222,128,0.15); color: #4ade80; border-color: rgba(74,222,128,0.3); }

/* CONTENT */
.content {
  padding: 12px;
  max-width: 680px;
  margin: 0 auto;
  padding-bottom: 100px;
}

.section { display: none; }
.section.active { display: block; }

/* DASHBOARD */
.dashboard-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 12px;
}

.stat-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 14px;
}

.stat-card.full { grid-column: 1/-1; }

.stat-label {
  font-size: 10px;
  color: var(--muted);
  font-weight: 600;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  margin-bottom: 6px;
}

.stat-value {
  font-size: 28px;
  font-weight: 700;
  font-family: 'DM Mono', monospace;
  color: var(--white);
  line-height: 1;
}

.stat-sub {
  font-size: 10px;
  color: var(--muted);
  margin-top: 3px;
}

/* PIE CHART */
.pie-section {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
}

.pie-title {
  font-size: 12px;
  font-weight: 700;
  color: var(--light);
  margin-bottom: 14px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.pie-title span {
  font-size: 10px;
  color: var(--muted);
  font-family: 'DM Mono', monospace;
}

.pie-container {
  display: flex;
  align-items: center;
  gap: 20px;
}

.pie-chart-wrap {
  position: relative;
  flex-shrink: 0;
}

.pie-center-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.pie-pct {
  font-size: 20px;
  font-weight: 700;
  color: var(--white);
  font-family: 'DM Mono', monospace;
  line-height: 1;
}

.pie-pct-label {
  font-size: 9px;
  color: var(--muted);
  margin-top: 2px;
}

.pie-legend {
  flex: 1;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 5px 0;
  border-bottom: 1px solid var(--border);
}

.legend-item:last-child { border-bottom: none; }

.legend-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  flex-shrink: 0;
}

.legend-name {
  font-size: 11px;
  color: var(--light);
  flex: 1;
}

.legend-val {
  font-size: 11px;
  font-family: 'DM Mono', monospace;
  color: var(--muted);
}

/* PLATFORM PROGRESS BARS */
.platform-progress {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 14px;
  margin-bottom: 12px;
}

.platform-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 6px 0;
  cursor: pointer;
}

.platform-row:hover .plat-name { color: var(--white); }

.plat-icon { font-size: 14px; width: 20px; text-align: center; }
.plat-name { font-size: 12px; color: var(--light); width: 90px; flex-shrink: 0; font-weight: 500; transition: color 0.15s; }

.plat-bar-wrap {
  flex: 1;
  background: rgba(255,255,255,0.06);
  border-radius: 6px;
  height: 6px;
  overflow: hidden;
}

.plat-bar {
  height: 100%;
  border-radius: 6px;
  transition: width 0.5s cubic-bezier(0.4,0,0.2,1);
}

.plat-count {
  font-size: 10px;
  font-family: 'DM Mono', monospace;
  color: var(--muted);
  width: 36px;
  text-align: right;
  flex-shrink: 0;
}

/* QUICK ACTIONS */
.quick-pending {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 14px;
  margin-bottom: 12px;
}

.quick-pending h3 {
  font-size: 11px;
  font-weight: 700;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 10px;
}

.quick-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 7px 0;
  border-bottom: 1px solid var(--border);
  cursor: pointer;
}

.quick-item:last-child { border-bottom: none; }

.quick-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}

.quick-text {
  font-size: 12px;
  color: var(--light);
  flex: 1;
  line-height: 1.3;
}

.quick-platform {
  font-size: 9px;
  color: var(--muted);
  background: var(--card2);
  border-radius: 4px;
  padding: 2px 5px;
  font-family: 'DM Mono', monospace;
}

/* PHASE */
.phase {
  margin-bottom: 10px;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid var(--border);
}

.phase-header {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 11px 14px;
  background: var(--card);
  cursor: pointer;
  user-select: none;
  border-left: 3px solid var(--teal);
}

.phase-header.col-green { border-left-color: var(--green); }
.phase-header.col-orange { border-left-color: var(--orange); }
.phase-header.col-purple { border-left-color: var(--purple); }
.phase-header.col-red { border-left-color: var(--red); }

.phase-title {
  font-size: 11px;
  font-weight: 700;
  color: var(--light);
  flex: 1;
  letter-spacing: 0.3px;
  text-transform: uppercase;
}

.phase-count {
  font-size: 10px;
  color: var(--muted);
  font-family: 'DM Mono', monospace;
}

.phase-chevron {
  font-size: 10px;
  color: var(--muted);
  transition: transform 0.2s;
}

.phase-chevron.open { transform: rotate(180deg); }

.phase-body { background: var(--card2); }

/* ITEM */
.item {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 11px 14px;
  border-bottom: 1px solid rgba(36,53,80,0.6);
  transition: background 0.15s;
  position: relative;
}

.item:last-child { border-bottom: none; }
.item:active { background: rgba(255,255,255,0.03); }
.item.completed { opacity: 0.55; }

.item-check {
  width: 20px;
  height: 20px;
  border: 1.5px solid var(--border);
  border-radius: 50%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s;
  margin-top: 1px;
}

.item.completed .item-check {
  background: #4ade80;
  border-color: #4ade80;
}

.check-icon { display: none; color: #0f1923; font-size: 10px; font-weight: 800; }
.item.completed .check-icon { display: block; }

.item-body { flex: 1; min-width: 0; }

.item-title {
  font-size: 13px;
  color: var(--text);
  line-height: 1.4;
  font-weight: 500;
  cursor: pointer;
}

.item.completed .item-title {
  text-decoration: line-through;
  color: var(--muted);
}

.item-note {
  font-size: 11px;
  color: var(--muted);
  margin-top: 3px;
  line-height: 1.4;
}

.item-remark {
  font-size: 11px;
  color: #fbbf24;
  margin-top: 4px;
  background: rgba(251,191,36,0.08);
  border-radius: 6px;
  padding: 4px 8px;
  border-left: 2px solid rgba(251,191,36,0.4);
  line-height: 1.4;
  font-style: italic;
}

.item-actions {
  display: flex;
  flex-direction: column;
  gap: 4px;
  flex-shrink: 0;
}

.act-btn {
  background: transparent;
  border: none;
  cursor: pointer;
  font-size: 13px;
  padding: 2px 4px;
  border-radius: 4px;
  transition: background 0.15s;
  color: var(--muted);
}

.act-btn:hover { background: rgba(255,255,255,0.06); color: var(--light); }

.priority-tag {
  display: inline-block;
  font-size: 9px;
  font-weight: 700;
  padding: 2px 6px;
  border-radius: 4px;
  margin-top: 3px;
  letter-spacing: 0.4px;
  font-family: 'DM Mono', monospace;
}

.tag-now { background: rgba(220,38,38,0.15); color: #f87171; }
.tag-week { background: rgba(234,88,12,0.15); color: #fb923c; }
.tag-ongoing { background: rgba(11,123,140,0.15); color: #22d3ee; }
.tag-later { background: rgba(124,58,237,0.15); color: #a78bfa; }

/* ADD TASK BUTTON */
.add-phase-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  width: 100%;
  padding: 10px;
  background: transparent;
  border: 1.5px dashed var(--border);
  border-radius: 10px;
  color: var(--muted);
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  margin-top: 8px;
  transition: all 0.15s;
  font-family: 'DM Sans', sans-serif;
}

.add-phase-btn:hover { border-color: var(--teal); color: var(--teal); background: rgba(11,123,140,0.05); }

/* MODAL */
.modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.7);
  z-index: 1000;
  backdrop-filter: blur(4px);
  align-items: flex-end;
  justify-content: center;
}

.modal-overlay.open { display: flex; }

.modal {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 20px 20px 0 0;
  padding: 20px 16px 32px;
  width: 100%;
  max-width: 680px;
  animation: slideUp 0.25s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.modal-handle {
  width: 40px;
  height: 4px;
  background: var(--border);
  border-radius: 2px;
  margin: 0 auto 16px;
}

.modal-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--white);
  margin-bottom: 14px;
}

.modal label {
  display: block;
  font-size: 11px;
  font-weight: 600;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 5px;
  margin-top: 12px;
}

.modal label:first-of-type { margin-top: 0; }

.modal input, .modal textarea, .modal select {
  width: 100%;
  background: var(--card2);
  border: 1px solid var(--border);
  border-radius: 8px;
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  padding: 10px 12px;
  outline: none;
  transition: border-color 0.15s;
}

.modal input:focus, .modal textarea:focus, .modal select:focus {
  border-color: var(--teal);
}

.modal textarea { min-height: 70px; resize: vertical; }

.modal select option { background: var(--card2); }

.modal-actions {
  display: flex;
  gap: 8px;
  margin-top: 16px;
}

.btn-primary {
  flex: 1;
  background: var(--teal);
  color: white;
  border: none;
  border-radius: 10px;
  padding: 12px;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  font-family: 'DM Sans', sans-serif;
  transition: opacity 0.15s;
}

.btn-primary:active { opacity: 0.8; }

.btn-secondary {
  background: var(--card2);
  color: var(--light);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 12px 20px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  font-family: 'DM Sans', sans-serif;
}

/* FLOATING ADD */
.fab {
  position: fixed;
  bottom: 24px;
  right: 16px;
  background: linear-gradient(135deg, var(--teal), #1B3A6B);
  color: white;
  border: none;
  border-radius: 50%;
  width: 52px;
  height: 52px;
  font-size: 22px;
  cursor: pointer;
  box-shadow: 0 4px 20px rgba(11,123,140,0.4);
  z-index: 300;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.15s;
}

.fab:active { transform: scale(0.93); }

/* TOAST */
.toast {
  position: fixed;
  bottom: 90px;
  left: 50%;
  transform: translateX(-50%) translateY(20px);
  background: rgba(74,222,128,0.15);
  color: #4ade80;
  border: 1px solid rgba(74,222,128,0.3);
  border-radius: 20px;
  padding: 8px 16px;
  font-size: 12px;
  font-weight: 600;
  opacity: 0;
  transition: all 0.3s;
  z-index: 999;
  white-space: nowrap;
  pointer-events: none;
}

.toast.show {
  opacity: 1;
  transform: translateX(-50%) translateY(0);
}

/* EMPTY STATE */
.empty {
  text-align: center;
  padding: 30px 20px;
  color: var(--muted);
}

.empty p { font-size: 13px; margin-top: 6px; }

/* GOOGLE SCRIPT GUIDE */
.guide-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 14px;
  margin-bottom: 10px;
}

.guide-card h3 {
  font-size: 12px;
  font-weight: 700;
  color: var(--teal);
  margin-bottom: 8px;
  text-transform: uppercase;
  letter-spacing: 0.4px;
}

.guide-step {
  display: flex;
  gap: 10px;
  padding: 7px 0;
  border-bottom: 1px solid var(--border);
  align-items: flex-start;
}

.guide-step:last-child { border-bottom: none; }

.step-num {
  width: 20px;
  height: 20px;
  background: var(--teal);
  color: white;
  border-radius: 50%;
  font-size: 10px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 1px;
}

.step-text { font-size: 12px; color: var(--light); line-height: 1.5; }
.step-code {
  font-family: 'DM Mono', monospace;
  background: var(--card2);
  border-radius: 4px;
  padding: 2px 6px;
  font-size: 11px;
  color: #22d3ee;
}

.copy-btn {
  display: block;
  width: 100%;
  background: var(--card2);
  border: 1px solid var(--border);
  color: var(--light);
  border-radius: 8px;
  padding: 10px;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  margin-top: 8px;
  font-family: 'DM Sans', sans-serif;
  transition: all 0.15s;
}

.copy-btn:hover { border-color: var(--teal); color: var(--teal); }
</style>
</head>
<body>

<!-- HEADER -->
<div class="header">
  <div class="header-top">
    <div class="header-title">
      <h1>MDV Digital Checklist</h1>
      <p>Menara Optometry Mid Valley · 2026</p>
    </div>
    <div class="header-actions">
      <button class="btn-icon" onclick="switchTab('guide')">📤 Export</button>
      <button class="btn-icon" onclick="confirmReset()">↺</button>
    </div>
  </div>
  <div class="global-progress">
    <div class="progress-track">
      <div class="progress-fill" id="globalBar" style="width:0%"></div>
    </div>
    <div class="progress-label" id="globalText">0 / 0</div>
  </div>
</div>

<!-- TABS -->
<div class="tabs-wrap">
  <div class="tabs">
    <div class="tab active" onclick="switchTab('dashboard')">📊 Dashboard</div>
    <div class="tab" onclick="switchTab('google')">📍 Google <span class="badge" id="b-google">0</span></div>
    <div class="tab" onclick="switchTab('whatsapp')">💬 WhatsApp <span class="badge" id="b-whatsapp">0</span></div>
    <div class="tab" onclick="switchTab('instagram')">📸 Instagram <span class="badge" id="b-instagram">0</span></div>
    <div class="tab" onclick="switchTab('facebook')">👍 Facebook <span class="badge" id="b-facebook">0</span></div>
    <div class="tab" onclick="switchTab('posts')">✍️ Posts <span class="badge" id="b-posts">0</span></div>
    <div class="tab" onclick="switchTab('guide')">🚀 Deploy</div>
  </div>
</div>

<div class="content">

  <!-- DASHBOARD -->
  <div class="section active" id="section-dashboard">

    <div class="pie-section">
      <div class="pie-title">
        Today's Progress
        <span id="pie-date"></span>
      </div>
      <div class="pie-container">
        <div class="pie-chart-wrap">
          <svg width="110" height="110" viewBox="0 0 110 110">
            <circle cx="55" cy="55" r="40" fill="none" stroke="rgba(255,255,255,0.05)" stroke-width="16"/>
            <circle cx="55" cy="55" r="40" fill="none" stroke="rgba(74,222,128,0.2)" stroke-width="16"
              id="pie-incomplete" stroke-dasharray="251.2" stroke-dashoffset="0"
              transform="rotate(-90 55 55)"/>
            <circle cx="55" cy="55" r="40" fill="none" stroke="#4ade80" stroke-width="16"
              id="pie-complete" stroke-dasharray="251.2" stroke-dashoffset="251.2"
              transform="rotate(-90 55 55)" stroke-linecap="round"
              style="transition: stroke-dashoffset 0.6s cubic-bezier(0.4,0,0.2,1)"/>
          </svg>
          <div class="pie-center-text">
            <div class="pie-pct" id="pie-pct">0%</div>
            <div class="pie-pct-label">done</div>
          </div>
        </div>
        <div class="pie-legend">
          <div class="legend-item">
            <div class="legend-dot" style="background:#4ade80"></div>
            <div class="legend-name">Completed</div>
            <div class="legend-val" id="leg-done">0</div>
          </div>
          <div class="legend-item">
            <div class="legend-dot" style="background:rgba(74,222,128,0.2)"></div>
            <div class="legend-name">Remaining</div>
            <div class="legend-val" id="leg-remain">0</div>
          </div>
          <div class="legend-item">
