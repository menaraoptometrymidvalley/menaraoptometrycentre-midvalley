const PLATFORM_COLORS = {
  google: '#1B3A6B', whatsapp: '#16a34a',
  instagram: '#e1306c', facebook: '#1877f2', posts: '#7c3aed'
};

const PRIORITY_LABELS = { now: 'DO TODAY', week: 'THIS WEEK', ongoing: 'ONGOING', later: 'WEEK 2+' };
const PRIORITY_CLASSES = { now: 'tag-now', week: 'tag-week', ongoing: 'tag-ongoing', later: 'tag-later' };

let appData = {};
let checkState = {};
let remarks = {};
let currentTab = 'dashboard';

// ============ STORAGE — localStorage (works everywhere: GitHub, local, GAS) ============
const STORAGE_KEY = 'mdv_v3';

function loadAll() {
  appData = JSON.parse(JSON.stringify(DEFAULT_DATA));
  checkState = {};
  remarks = {};
}

function loadSaved() {
  try {
    var r = localStorage.getItem(STORAGE_KEY);
    if (r) {
      var p = JSON.parse(r);
      if (p.appData) appData = p.appData;
      if (p.checkState) checkState = p.checkState;
      if (p.remarks) remarks = p.remarks;
    }
  } catch(e) {}
}

function saveAll() {
  try {
    localStorage.setItem(STORAGE_KEY, JSON.stringify({appData, checkState, remarks}));
  } catch(e) {}
}

// ============ RENDER ============
function getAllItems() {
  let items = [];
  Object.keys(appData).forEach(key => {
    appData[key].phases.forEach(phase => {
      phase.items.forEach(item => {
        items.push({ ...item, section: key, phaseId: phase.id });
      });
    });
  });
  return items;
}

function getSectionStats(key) {
  let total = 0, done = 0;
  appData[key].phases.forEach(phase => {
    phase.items.forEach(item => {
      total++;
      if (checkState[item.id]) done++;
    });
  });
  return { total, done };
}

function renderDashboard() {
  const all = getAllItems();
  const total = all.length;
  const done = all.filter(i => checkState[i.id]).length;
  const pct = total > 0 ? Math.round((done / total) * 100) : 0;

  // Pie
  const circ = 251.2;
  const offset = circ - (circ * pct / 100);
  document.getElementById('pie-complete').style.strokeDashoffset = offset;
  document.getElementById('pie-pct').textContent = pct + '%';
  document.getElementById('leg-done').textContent = done;
  document.getElementById('leg-remain').textContent = total - done;
  document.getElementById('leg-urgent').textContent = all.filter(i => !checkState[i.id] && i.priority === 'now').length;
  document.getElementById('leg-week').textContent = all.filter(i => !checkState[i.id] && i.priority === 'week').length;
  document.getElementById('pie-date').textContent = new Date().toLocaleDateString('en-MY', { day:'numeric', month:'short' });

  // Platform bars
  const barsEl = document.getElementById('platform-bars');
  barsEl.innerHTML = Object.keys(appData).map(key => {
    const s = getSectionStats(key);
    const p = s.total > 0 ? Math.round(s.done / s.total * 100) : 0;
    return `<div class="platform-row" onclick="switchTab('${key}')">
      <span class="plat-icon">${appData[key].icon}</span>
      <span class="plat-name">${appData[key].label.split(' ')[0]}</span>
      <div class="plat-bar-wrap">
        <div class="plat-bar" style="width:${p}%;background:${PLATFORM_COLORS[key]}"></div>
      </div>
      <span class="plat-count">${s.done}/${s.total}</span>
    </div>`;
  }).join('');

  // Urgent list
  const urgent = all.filter(i => !checkState[i.id] && i.priority === 'now');
  const urgentEl = document.getElementById('urgent-list');
  urgentEl.innerHTML = urgent.length === 0
    ? '<div style="font-size:12px;color:#4ade80;padding:4px 0">✓ All done today!</div>'
    : urgent.slice(0, 6).map(i => `
      <div class="quick-item" onclick="switchTab('${i.section}')">
        <div class="quick-dot" style="background:#f87171"></div>
        <div class="quick-text">${i.title}</div>
        <span class="quick-platform">${appData[i.section].label.split(' ')[0]}</span>
      </div>`).join('') + (urgent.length > 6 ? `<div style="font-size:11px;color:var(--muted);padding:5px 0">+${urgent.length-6} more</div>` : '');

  // Week list
  const weekItems = all.filter(i => !checkState[i.id] && i.priority === 'week');
  const weekEl = document.getElementById('week-list');
  weekEl.innerHTML = weekItems.length === 0
    ? '<div style="font-size:12px;color:#4ade80;padding:4px 0">✓ All this week\'s tasks done!</div>'
    : weekItems.slice(0, 6).map(i => `
      <div class="quick-item" onclick="switchTab('${i.section}')">
        <div class="quick-dot" style="background:#fb923c"></div>
        <div class="quick-text">${i.title}</div>
        <span class="quick-platform">${appData[i.section].label.split(' ')[0]}</span>
      </div>`).join('') + (weekItems.length > 6 ? `<div style="font-size:11px;color:var(--muted);padding:5px 0">+${weekItems.length-6} more</div>` : '');
}

function renderSection(key) {
  const container = document.getElementById('items-' + key);
  if (!container) return;
  const sec = appData[key];
  let html = '';

  sec.phases.forEach(phase => {
    const pDone = phase.items.filter(i => checkState[i.id]).length;
    html += `<div class="phase">
      <div class="phase-header ${phase.color || ''}" onclick="togglePhase('pb_${phase.id}', 'pc_${phase.id}')">
        <span class="phase-title">${phase.title}</span>
        <span class="phase-count">${pDone}/${phase.items.length}</span>
        <span class="phase-chevron open" id="pc_${phase.id}">▼</span>
      </div>
      <div class="phase-body" id="pb_${phase.id}">`;

    if (phase.items.length === 0) {
      html += '<div class="empty"><p>No tasks yet. Tap + to add one.</p></div>';
    }

    phase.items.forEach(item => {
      const done = !!checkState[item.id];
      const remark = remarks[item.id] || '';
      html += `<div class="item ${done ? 'completed' : ''}" id="item_${item.id}">
        <div class="item-check" onclick="toggleCheck('${item.id}')">
          <span class="check-icon">✓</span>
        </div>
        <div class="item-body" onclick="toggleCheck('${item.id}')">
          <div class="item-title">${item.title}</div>
          ${item.note ? `<div class="item-note">${item.note}</div>` : ''}
          <span class="priority-tag ${PRIORITY_CLASSES[item.priority]}">${PRIORITY_LABELS[item.priority]}</span>
          ${remark ? `<div class="item-remark">📝 ${remark}</div>` : ''}
        </div>
        <div class="item-actions">
          <button class="act-btn" onclick="openRemarkModal('${item.id}','${escHtml(remark)}')" title="Add remark">💬</button>
          <button class="act-btn" onclick="openEditModal('${item.id}','${key}')" title="Edit">✏️</button>
          <button class="act-btn" onclick="deleteItem('${item.id}','${key}')" title="Delete">🗑️</button>
        </div>
      </div>`;
    });

    html += `</div></div>`;
    html += `<button class="add-phase-btn" onclick="openAddModal('${key}','${phase.id}')">+ Add task to "${phase.title}"</button>`;
  });

  container.innerHTML = html;

  // Badge
  const s = getSectionStats(key);
  const badge = document.getElementById('b-' + key);
  if (badge) {
    badge.textContent = s.done + '/' + s.total;
    badge.className = 'badge' + (s.done === s.total && s.total > 0 ? ' complete' : '');
  }
}

function renderGlobal() {
  const all = getAllItems();
  const total = all.length;
  const done = all.filter(i => checkState[i.id]).length;
  const pct = total > 0 ? Math.round(done / total * 100) : 0;
  document.getElementById('globalBar').style.width = pct + '%';
  document.getElementById('globalText').textContent = done + ' / ' + total;
}

function render() {
  renderGlobal();
  Object.keys(appData).forEach(key => renderSection(key));
  renderDashboard();
}

// ============ INTERACTIONS ============
function toggleCheck(id) {
  checkState[id] = !checkState[id];
  saveAll();
  render();
  showToast(checkState[id] ? '✓ Marked complete' : 'Unmarked');
}

function togglePhase(bodyId, chevronId) {
  const body = document.getElementById(bodyId);
  const chev = document.getElementById(chevronId);
  if (!body) return;
  const hidden = body.style.display === 'none';
  body.style.display = hidden ? 'block' : 'none';
  if (chev) chev.classList.toggle('open', hidden);
}

function switchTab(tab) {
  currentTab = tab;
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  const tabMap = ['dashboard','google','whatsapp','instagram','facebook','posts','guide'];
  document.querySelectorAll('.tab').forEach((t, i) => {
    if (tabMap[i] === tab) t.classList.add('active');
  });
  document.querySelectorAll('.section').forEach(s => {
    s.classList.toggle('active', s.id === 'section-' + tab);
  });
  const fab = document.getElementById('fab');
  fab.style.display = (tab === 'guide' || tab === 'dashboard') ? 'none' : 'flex';
  if (tab === 'dashboard') renderDashboard();
}

// ============ ADD/EDIT MODAL ============
let currentAddSection = null;
let currentAddPhase = null;
let currentEditId = null;

function openAddModal(sectionKey, phaseId) {
  currentAddSection = sectionKey || currentTab;
  currentAddPhase = phaseId || null;
  currentEditId = null;

  document.getElementById('modalTitle').textContent = 'Add New Task';
  document.getElementById('taskTitle').value = '';
  document.getElementById('taskNote').value = '';
  document.getElementById('taskRemark').value = '';
  document.getElementById('taskSection').value = currentAddSection;
  document.getElementById('taskPriority').value = 'week';
  updatePhaseDropdown(currentAddSection, phaseId);
  document.getElementById('taskModal').classList.add('open');
}

function openEditModal(itemId, sectionKey) {
  currentEditId = itemId;
  currentAddSection = sectionKey;

  let found = null;
  appData[sectionKey].phases.forEach(phase => {
    phase.items.forEach(item => {
      if (item.id === itemId) { found = item; currentAddPhase = phase.id; }
    });
  });

  if (!found) return;
  document.getElementById('modalTitle').textContent = 'Edit Task';
  document.getElementById('taskTitle').value = found.title;
  document.getElementById('taskNote').value = found.note || '';
  document.getElementById('taskRemark').value = remarks[itemId] || '';
  document.getElementById('taskSection').value = sectionKey;
  document.getElementById('taskPriority').value = found.priority;
  updatePhaseDropdown(sectionKey, currentAddPhase);
  document.getElementById('taskModal').classList.add('open');
}

function updatePhaseDropdown(sectionKey, selectedPhaseId) {
  const select = document.getElementById('taskPhase');
  if (!appData[sectionKey]) return;
  select.innerHTML = appData[sectionKey].phases.map(p =>
    `<option value="${p.id}" ${p.id === selectedPhaseId ? 'selected' : ''}>${p.title}</option>`
  ).join('');
}

document.getElementById('taskSection').addEventListener('change', function() {
  updatePhaseDropdown(this.value, null);
});

function saveTask() {
  const title = document.getElementById('taskTitle').value.trim();
  if (!title) { showToast('Please enter a task title'); return; }

  const sectionKey = document.getElementById('taskSection').value;
  const phaseId = document.getElementById('taskPhase').value;
  const note = document.getElementById('taskNote').value.trim();
  const remark = document.getElementById('taskRemark').value.trim();
  const priority = document.getElementById('taskPriority').value;

  if (currentEditId) {
    // Edit existing
    appData[sectionKey].phases.forEach(phase => {
      phase.items.forEach(item => {
        if (item.id === currentEditId) {
          item.title = title;
          item.note = note;
          item.priority = priority;
        }
      });
    });
    if (remark) remarks[currentEditId] = remark;
    else delete remarks[currentEditId];
  } else {
    // Add new
    const newId = 'custom_' + Date.now();
    const phase = appData[sectionKey].phases.find(p => p.id === phaseId);
    if (phase) {
      phase.items.push({ id: newId, title, note, priority });
      if (remark) remarks[newId] = remark;
    }
  }

  saveAll();
  render();
  closeModal();
  showToast(currentEditId ? '✓ Task updated' : '✓ Task added');
}

function closeModal() {
  document.getElementById('taskModal').classList.remove('open');
}

// ============ REMARK MODAL ============
function openRemarkModal(itemId, existingRemark) {
  document.getElementById('remarkItemId').value = itemId;
  document.getElementById('remarkText').value = existingRemark || '';
  document.getElementById('remarkModal').classList.add('open');
}

function saveRemark() {
  const id = document.getElementById('remarkItemId').value;
  const text = document.getElementById('remarkText').value.trim();
  if (text) remarks[id] = text;
  else delete remarks[id];
  saveAll();
  render();
  closeRemarkModal();
  showToast('✓ Remark saved');
}

function closeRemarkModal() {
  document.getElementById('remarkModal').classList.remove('open');
}

// ============ DELETE ============
function deleteItem(itemId, sectionKey) {
  if (!confirm('Delete this task?')) return;
  appData[sectionKey].phases.forEach(phase => {
    phase.items = phase.items.filter(i => i.id !== itemId);
  });
  delete checkState[itemId];
  delete remarks[itemId];
  saveAll();
  render();
  showToast('Task deleted');
}

// ============ RESET ============
function confirmReset() {
  if (confirm('Reset all progress? Tasks will remain but all checkmarks will be cleared.')) {
    checkState = {};
    saveAll();
    render();
    showToast('Progress reset');
  }
}

// ============ EXPORT ============
function exportData() {
  const exportObj = { appData, checkState, remarks, exported: new Date().toISOString() };
  const json = JSON.stringify(exportObj, null, 2);
  try {
    navigator.clipboard.writeText(json);
    showToast('✓ Data copied to clipboard');
  } catch(e) {
    const ta = document.createElement('textarea');
    ta.value = json;
    document.body.appendChild(ta);
    ta.select();
    document.execCommand('copy');
    document.body.removeChild(ta);
    showToast('✓ Data copied');
  }
}



// ============ TOAST ============
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2000);
}

function escHtml(str) {
  return (str || '').replace(/'/g, "\\'").replace(/"/g, '&quot;');
}

// Close modals on overlay click
document.querySelectorAll('.modal-overlay').forEach(overlay => {
  overlay.addEventListener('click', function(e) {
    if (e.target === this) {
      closeModal();
      closeRemarkModal();
    }
  });
});

// Date display
document.getElementById('pie-date').textContent = new Date().toLocaleDateString('en-MY', { weekday:'short', day:'numeric', month:'short' });

// ============ INIT ============
window.onload = function() {
  loadAll();
  loadSaved();
  render();
  switchTab('dashboard');
};
</script>
